{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "paths": {
      "@frontend/*": ["./packages/frontend/src/*"],
      "@api/*": ["./packages/api/src/*"]
    }
  },
  "exclude": [
    "node_modules",
    "**/dist",
    "**/.wrangler"
  ]
}
